{
	"type": "module",
	"name": "ts-template",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"typecheck": "tsc --noEmit --project configs/tsconfig/tsconfig.test.json",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "biome format . && prettier .",
		"format:fix": "biome format . --write && prettier --write .",
		"check": "biome check . && prettier .",
		"check:fix": "biome check . --write && prettier --write .",
		"prepare": "lefthook install",
		"typespec": "tsp"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.4",
		"@commitlint/cli": "19.8.1",
		"@types/node": "22.13.14",
		"@typespec/compiler": "1.9.0",
		"@typespec/http": "1.9.0",
		"@typespec/openapi": "1.9.0",
		"@typespec/openapi3": "1.9.0",
		"@typespec/rest": "0.79.0",
		"lefthook": "1.13.0",
		"plop": "4.0.4",
		"prettier": "3.6.2",
		"serve": "14.2.5",
		"tsx": "4.20.6",
		"typescript": "5.9.2",
		"vite": "7.1.5"
	},
	"packageManager": "pnpm@10.24.0"
}
